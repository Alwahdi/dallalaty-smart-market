{
  "expo": {
    "name": "دلالتي - السوق الذكي",
    "slug": "dallalaty-smart-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "dallalaty",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf8f0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alwahdi.dallalaty",
      "infoPlist": {
        "NSCameraUsageDescription": "نحتاج الوصول للكاميرا لتصوير العقارات والمنتجات",
        "NSPhotoLibraryUsageDescription": "نحتاج الوصول للصور لاختيار صور العقارات والمنتجات",
        "NSLocationWhenInUseUsageDescription": "نحتاج الوصول للموقع لعرض العقارات القريبة منك"
      }
    },
    "android": {
      "package": "com.alwahdi.dallalaty",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#faf8f0"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#c4972a",
          "sounds": []
        }
      ],
      [
        "expo-updates",
        {
          "username": "alwahdi"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول للصور لاختيار صور العقارات والمنتجات",
          "cameraPermission": "نحتاج الوصول للكاميرا لتصوير العقارات والمنتجات"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/your-project-id-here"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
